---
// src/components/YearToggleList.astro
import itemsData from '../data/curr.json';

// Group items by year
const groupedItems = itemsData.items.reduce((acc, item) => {
    if (!acc[item.year]) {
        acc[item.year] = [];
    }
    acc[item.year].push(item);
    return acc;
}, {});

// Sort years in descending order
const sortedYears = Object.keys(groupedItems)
    .map(Number)
    .sort((a, b) => b - a);
---

<div class="year-toggle-list">
    {
        sortedYears.map((year) => (
            <div class="year-section">
                <button class="year-toggle">
                    <span class="year-label">{year}</span>
                    <span class="toggle-icon">▼</span>
                </button>
                <div class="year-content">
                    {groupedItems[year].map((item) => (
                        <div class="item">
                            <h3>{item.title}</h3>
                            <p>{item.description}</p>
                        </div>
                    ))}
                </div>
            </div>
        ))
    }
</div>

<style>
    /* Theme variables */
    :root {
        --background: #ffffff;
        --surface: #f8f8f8;
        --surface-hover: #f0f0f0;
        --border: #eee;
        --text-primary: #333;
        --text-secondary: #666;
    }

    @media (prefers-color-scheme: dark) {
        :root {
            --background: #1a1a1a;
            --surface: #2a2a2a;
            --surface-hover: #333333;
            --border: #404040;
            --text-primary: #ffffff;
            --text-secondary: #a0a0a0;
        }
    }

    /* You can also support manual theme toggling by adding these classes */
    :root[data-theme='dark'] {
        --background: #1a1a1a;
        --surface: #2a2a2a;
        --surface-hover: #333333;
        --border: #404040;
        --text-primary: #ffffff;
        --text-secondary: #a0a0a0;
    }

    :root[data-theme='light'] {
        --background: #ffffff;
        --surface: #f8f8f8;
        --surface-hover: #f0f0f0;
        --border: #eee;
        --text-primary: #333;
        --text-secondary: #666;
    }

    .year-toggle-list {
        max-width: 800px;
        margin: 2rem auto;
        font-family:
            system-ui,
            -apple-system,
            sans-serif;
        color: var(--text-primary);
    }

    .year-section {
        margin-bottom: 1rem;
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        background: var(--background);
    }

    .year-toggle {
        width: 100%;
        padding: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: var(--surface);
        border: none;
        cursor: pointer;
        transition: background-color 0.2s ease;
        color: var(--text-primary);
    }

    .year-toggle:hover {
        background: var(--surface-hover);
    }

    .year-label {
        font-size: 1.25rem;
        font-weight: 600;
    }

    .toggle-icon {
        transition: transform 0.2s ease;
    }

    .year-content {
        display: none;
        padding: 1rem;
    }

    .item {
        padding: 1rem;
        border-bottom: 1px solid var(--border);
    }

    .item:last-child {
        border-bottom: none;
    }

    .item h3 {
        margin: 0 0 0.5rem 0;
        font-size: 1.1rem;
        color: var(--text-primary);
    }

    .item p {
        margin: 0;
        color: var(--text-secondary);
    }

    .year-section.active .toggle-icon {
        transform: rotate(180deg);
    }

    .year-section.active .year-content {
        display: block;
    }
</style>

<script>
    function initializeYearToggles() {
        const toggleButtons = document.querySelectorAll('.year-toggle');

        toggleButtons.forEach((button) => {
            button.addEventListener('click', () => {
                const yearSection = button.parentElement;
                yearSection.classList.toggle('active');
            });
        });
    }

    // Initialize on page load
    initializeYearToggles();

    // Initialize when page content updates (for Astro view transitions)
    document.addEventListener('astro:page-load', initializeYearToggles);

    // Optional: Handle manual theme toggling
    function handleThemeToggle(theme) {
        document.documentElement.setAttribute('data-theme', theme);
    }
</script>
